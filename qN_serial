    """Bypass occurs during alias scanning to allow main window to skip init"""
    def slot_connect(self, bypass=False):
        self.serialport_name = self.qcb_ports.currentText()
        self.serialport = QSerialPort()
        if self.aliasActive:
            aliasName = self.serialport_name
            self.serialport_name = self.serports[self.serialport_name] # this is a dict
        self.serialport.setPortName(self.serialport_name)
        self.serialport.setBaudRate(
            self.baudrates[self.qcb_baudrates.currentText()]
        )
        self.serialport.setDataBits(
            self.databits[self.qcb_databits.currentText()]
        )
        self.serialport.setParity(
            self.paritybit[self.qcb_paritybit.currentText()]
        )
        self.serialport.setStopBits(
            self.stopbits[self.qcb_stopbits.currentText()]
        )
        self.serialport.setFlowControl(QSerialPort.NoFlowControl)
        self.serialport.open(QIODevice.ReadWrite)
        if self.serialport.isOpen():
            self.serialport.readyRead.connect(self.ready_read)
            self.qpb_connect_disconnect.setText("Disconnect")
            self.qpb_connect_disconnect.disconnect()
            self.qpb_connect_disconnect.clicked.connect(self.slot_disconnect)
        
            self.qcb_ports.setDisabled(True)
            self.qcb_baudrates.setDisabled(True)
            self.qcb_databits.setDisabled(True)
            self.qcb_paritybit.setDisabled(True)
            self.qcb_stopbits.setDisabled(True)
            self.qcb_flowcontrol.setDisabled(True)
            self.qcb_lineending.setDisabled(True)
            self.qpb_refresh.setDisabled(True)
            # self.qpb_load_session.setDisabled(True)
            if self.aliasActive:
                self.display(f'Connected successfully to {aliasName} at {self.serialport_name}')
            else:
                self.display(f'Connected successfully to {self.serialport_name}')
            if not bypass:
                self.serialOpen.emit(True)
        else:
            self.display(f'Something went wrong while connecting to {self.serialport_name}. Try again or check connection.')

    def trySN(self,prevSN=''):
        SN = self.ping()
        print(SN)
        if SN==prevSN:
            self.display(f'No qNimble or timeout on port {self.qcb_ports.currentText()}')
            return ''
        else:
            if len(SN) != 7:
                self.display(f'Message not fully received. Retrying...')
                return self.trySN(prevSN=prevSN)
            else:
                return SN


    """This takes in an alias file allows terminal to access aliases as a dict."""
    def update_aliases(self):
        flag,qNAliases = self.loadAliases() # TODO: Add custom alias file name?
        # if the alias loading was unsuccesful, just load ports. 
        if not flag:
            return (False,None)
              
        # Alias loading succesful, create ordered list
        qNList = OrderedDict() # Verified qNs
        port_index = self.qcb_ports.count() - 1
        # TODO: This performs a crude check. I couldn't get the slots to play 
        # right for connect disconnect without a blocking statement, so I use 
        # waitForReadyRead(). I also do a crude check for new data, which can 
        # be improved for versatility. It may not really matter. 
        last_SN = ''
        for i in range(self.qcb_ports.count()):
            # Update combo box text
            self.qcb_ports.setCurrentIndex(i)
            if (not (self.serialport == None)) and self.serialport.isOpen():
                self.slot_disconnect(bypass=True)
            self.slot_connect(bypass=True)
            if self.serialport.isOpen():
                SN = self.trySN(last_SN)
                try:
                    alias = qNAliases[SN]
                except:
                    alias = None
                if not (alias is None):
                    # Handle aliases
                    key = self.serialport.portName() + ":" + SN + ":" + alias
                    qNList[key] = self.serialport.portName()
                    self.display(f'Successffully found port with matching alias - creating {key}')
                    # qNCOMList.append(SN)
                else:
                    self.display(f'No qNimble or potential timeout on port {self.qcb_ports.currentText()}')
                self.slot_disconnect(bypass=True)
                last_SN = self.read_last()

            else:
                # terminal display
                self.display(f'Could not open port {self.qcb_ports.currentText()}')

        return (True,qNList)

    """This is essentially an internal message to the console"""
    def display(self,msg, err = False):
        flag = self.fl_autoscroll
        if err:
            msg = 'ERR:  ' + msg
        else:
            msg = 'INT:  ' + msg
        
        if not flag:
            v_val = self.qtb_receiver.verticalScrollBar().value()
            h_val = self.qtb_receiver.horizontalScrollBar().value()
        self.qtb_receiver.moveCursor(QTextCursor.End)
        self.qtb_receiver.insertPlainText(msg + '\n')
        if not flag:
            self.qtb_receiver.verticalScrollBar().setValue(v_val)
            self.qtb_receiver.horizontalScrollBar().setValue(h_val) 
        if not self.logfile.closed: # we add this to stop infinite recursion
            self.slot_log_data(msg)
        # print(msg) 

