    """setADCsampleConfig sets and returns the state of each channel"""
    def setADCsampleConfig(self, state1, state2, state3, state4):
        if (self.stateTypeFailure(state1) or 
            self.stateTypeFailure(state2) or 
            self.stateTypeFailure(state3) or 
            self.stateTypeFailure(state4)):
            self.display('Incorrect types for ADC sample config - must be four booleans.', err=True)
            return ''
        return self.feed(f'setconfig {int(state1)} {int(state2)} {int(state3)} {int(state4)}')

    # A few things get returned from this call, we will just use a binary interpretation.
    def getADCsampleConfig(self,channel):
        if self.chanTypeFailure(channel):
            return ''
        ret = self.feed('config').split('\n')
        if len(ret) == 1 or len(ret) > 3:
            # There was a chopped string, restart
            self.display('Returned string was not received correctly. Retrying...', err=True)
            return self.getADCsampleConfig(channel)
        return bool(eval(ret[1].split(',')[channel-1].strip()))
    
    def getADCsampleResolution(self):
        return self.feed('res')
    
    # Servo commands
    def enableServo(self, channel, state):
        if self.chanTypeFailure(channel):
            return ''
        if self.stateTypeFailure(state):
            return ''
        self.feed(f'enable {channel} {int(state)}')
        return self.getServoStates()
    
