    def getFeedState(self,channel):
        if self.chanTypeFailure():
            return ''
        state = read_state(self.getFeedStates(),channel)
        self.display(f'Feeding on {channel} is {int(state)}')
        return state

    def resetServo(self, channel):
        if self.chanTypeFailure(channel):
            return ''
        return self.feed(f'reset{channel}')

    def adjustHold(self, state):
        if self.stateTypeFailure(state):
            return ''
        # Default state is set in firmware to 1. Really the firmware should be changed
        # to allow us to alter this, but we can make a workaround to handle. 
        state = int(state)
        self.slot_input('flip')
        self.serialport.waitForReadyRead(100) # This adjustment takes a longer time to read
        resp = self.read_last()
        resp = bool(eval(resp[-1]))
        # self.display(f'Hold logic now flipped to {int(resp)}')
        if state != resp:
            self.display(f'Hold logic was flipped to {int(resp)} where {int(state)} was desired. Reflipping...')
            self.feed('flip')
        return ''

    # Rails and other servo commands
    def setRails(self, channel, min, max):
        if self.chanTypeFailure(channel):
            return ''
        if self.valueTypeFailure(min) or self.valueTypeFailure(max):
            return ''
        if min > max:
            self.display('Min is greater than max.',err=True)
            return ''
        else:
            if min < 0:
                self.display('WARNING: Voltage min less than 0 V will produce undesired mixer effects!')
            if max > 3:
                self.display('WARNING: Voltage max greater than 3 V may break a mixer!')
            return self.feed(f'rails {channel} {min} {max}')

    def getRails(self,channel):
        if self.chanTypeFailure(channel):
            return ''
        return self.feed(f'extremes {channel}')

    def setADCRange(self,channel,range):
        if self.chanTypeFailure(channel):
            return ''
        if self.valueTypeFailure(range):
            return ''
        if range < 0:
            self.display('Range must be greater than 0!', err=True)
            return ''
        return self.feed(f'range {channel} {range}')


