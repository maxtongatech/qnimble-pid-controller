    # Error checking
    def chanTypeFailure(self, channel):
        if type(channel) != int:
            self.display('Channel type incorrect.', err = True)
            return True
        if channel > 4 or channel < 1:
            self.display('Channel number out of range - must be 1 thru 4.', err = True)
            return True
        return False
    
    def stateTypeFailure(self, state):
        if type(state) != bool:
            if ((type(state) == int) and (state != 0 or state != 1)):
                if state < 0 or state > 1:
                    self.display('State type incorrect. Must be 0, 1, or boolean.', err=True)
                    return True
        return False

    def valueTypeFailure(self, value):
        if type(value) != int and type(value) != float:
            self.display('Value must be a number.', err = True)
            return True
        return False
    
    ############################ PID PARAMS ###############################
    # This just so happens to return every parameter known to man...
    def getAllPIDParams(self):
        return self.feed('get prop')
        
    def getChannelPIDParams(self,channel,var=''):
        if self.chanTypeFailure(channel):
            return ''
        # We are going to parse this to return the desired information
        raw_data = self.feed(f'get {channel}')
        channel_data = raw_data.split(':')[1].split(',')
        for prop in channel_data:
            key, val = prop.split('=')
            if var == key.strip():
                # This is the variable we want
                value = float(val.strip())
        return value

    # Proportional gain constant commands
    def getProp(self,channel):
        if self.chanTypeFailure(channel):
            return ''
        else:
            return float(self.getChannelPIDParams(channel,var='prop'))
    
