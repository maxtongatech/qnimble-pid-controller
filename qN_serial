    def getServoStates(self,lag=False):
        data = self.feed('is 0',lag=lag).split()[-4:]
        if len(data) != 4 or len(data[0].strip()) > 1:
            return self.getServoStates()
        return data
    
    def getServoState(self,channel):
        if self.chanTypeFailure():
            return ''
        state = read_state(self.getServoStates(),channel)
        self.display(f'Servo on {channel} is {int(state)}')
        return state

