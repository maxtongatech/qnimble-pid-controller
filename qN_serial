    ############################ SWEEP PARAMS ###############################
    # Sweep params
    def getChannelSweepParams(self,channel,var=''):
        if self.chanTypeFailure(channel):
            return ''
        if var == '':
            self.feed(f'getSweep {channel}')
            return self.read_last()
        else:
            raw_data = self.feed(f'getSweep {channel}')
            channel_data = raw_data.split(':')[1].split(',')
            for prop in channel_data:
                key, val = prop.split('=')
                if var == key.strip():
                    # This is the variable we want
                    value = float(val.strip())
            return value
    
    def getAllSweepParams(self):
        for i in range(4):
            self.feed(f'getSweep {i+1}')
        return ''

    # Sweep
    def setSweepType(self,channel,sweep):
        if self.chanTypeFailure(channel):
            return ''
        if type(sweep) == str:
            types = ['sin', 'saw', 'tri']
            if sweep not in types:
                self.display('Not a valid sweep type. Must be \'sin\', \'saw\', or \'tri\'.', err=True)
                return ''
            val = types.index(sweep)
            return self.feed(f'sweepType {channel} {val}')
        elif type(sweep) == int:
            if sweep < 0 or sweep > 2:
                self.display('Not a valid sweep type. Must be 0, 1, or 2',err=True)
                return ''
            return self.feed(f'sweepType {channel} {sweep}')
        else:
            self.display('Sweeep type must be a string or int.',err=True)
            return ''
            
    def getSweepType(self,channel):
