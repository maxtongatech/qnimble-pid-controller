"""
This helps us keep the correct format for our log filenames!
Format is MM-DD-YYYY_HHMM.log where HHMM is military time
"""
from datetime import datetime
def formate_filename():
    now = datetime.now()

    date_str = now.strftime("%m-%d-%Y")
    time_str = now.strftime("%H%M")
    return f"{date_str}_{time_str}-qN.log"

"""
This allows you to do functional calls for the qNimble without having
to memorize the different functional calls for the servo
"""
import inspect
def get_class_methods():
    all_methods = inspect.getmembers(SerialTerminalWidget, predicate=inspect.isfunction)
    
    # Get methods defined specifically in this class, not in parent classes
    class_methods = []
    for name, method in all_methods:
        if method.__qualname__.startswith(SerialTerminalWidget.__name__ + '.'):
            class_methods.append(name)
    return class_methods

"""Assumes a text of format ATTR: s1 s2 s3 s4"""
def read_state(txt,channel):
    return bool(eval(txt.split(':')[-1].strip().split(' ')[channel-1]))

