    """
    We want to display a few types of messages:
    - Any input that was written to the terminal
    - Any functional call that we use as an alias
    Thus, an internal flag is needed to differentiate between these two. 
    """
    def slot_input(self, cmd=''):
        if self.serialport:
            txt = ''
            if type(cmd) == bool:
                self.display('Whitespace message - nothing sent!')
            else: 
                if len(cmd)>0:
                    txt = cmd
                else:
                    txt = self.qle_sender.text()
                text_to_send = txt
                bytes_to_send = bytes(text_to_send + self.lineending, "utf-8")
                if self.fl_hexinput is True and text_to_send.find('\\x') == 0:
                    self.serialport.writeData(bytes.fromhex(text_to_send[2:]))
                else:
                    self.serialport.writeData(bytes_to_send)
                # Add to the text box
                flag = self.fl_autoscroll
                msg = 'SND:  ' + txt
                if not flag:
                    v_val = self.qtb_receiver.verticalScrollBar().value()
                    h_val = self.qtb_receiver.horizontalScrollBar().value()
                self.qtb_receiver.moveCursor(QTextCursor.End)
                self.qtb_receiver.insertPlainText(msg + '\n')
                if not flag:
                    self.qtb_receiver.verticalScrollBar().setValue(v_val)
                    self.qtb_receiver.horizontalScrollBar().setValue(h_val) 
                self.slot_log_data(msg)
        self.textFinished.emit(True)

    """
    Condensed everything to call log_data here in one command instead of spread over everything.
    """
    def slot_log_data(self,msg):
        # Check if logger is open
        if not self.logfile.closed:
            # Do a quick check if there is a \n - add if not!
            if msg.find('\n') == -1:
                msg = msg + '\n'
            self.logfile.write(msg)
        else:
            print('Logfile deleted or corrupted. Cannot log command.')
    
    """Feeds a command to the terminal. These are always internal commands."""
    def feed(self, cmd, lag=False):
        self.internal = True
        self.slot_input(cmd)
        if lag:
            self.serialport.waitForReadyRead(500)
        else:
            self.serialport.waitForReadyRead(10)
        return self.read_last()
    
    """
    Loads an alias file. Returns a tuple containing the dict and flag that indicates 
    if the file was opened properly. 
    TODO: Allow path to alias filename
    """
    def loadAliases(self):
        # load PID aliases from a local .tsv file called "qNimbleAliases.tsv"
        filename = "qNimbleAliases.tsv"
        self.display("Loading qNimble aliases...")
        aliasesDict = dict()
        success = False
        try:
            with open(filename, 'r') as file:
                for line in file:
                    line = line[0:len(line)-1] # strip EOL
                    try:
                        key = line.split("\t")[0]
                        alias = line.split("\t")[1]
                        if ((len(key)>0) and (len(alias))>0):
                            aliasesDict[key] = alias
                    except:
                        pass
            success = True
        except IOError:
            pass
            self.display(f"Could not open {filename}")
        self.display(f"Found aliases in {filename}:")
        for key in aliasesDict:
            self.display(key + ":" + aliasesDict[key])
        self.display(f'Finished reading {filename}')
        return (success, aliasesDict)
    
    """Handles closing / indirect crashing if parent is closed."""
    def close(self):
        self.display('Close detected. Closing ports and logfile...')
        if self.serialport.isOpen():
            self.slot_disconnect() # disconnect if port is open
        self.logfile.close()
    
    def isConnected(self):
        return self.serialport.isOpen()
    
    """
    This helps determine if the call was a "functional" call from
    the GUI. This has the ability to be kinda wonky, but we determine
    that a call is functional if it contains ()
    """
    def isFunction(self,txt):
        if '(' in txt and ')' in txt:
            # We believe this is a functional call!
            index = txt.index('(') # Strip the function and determine if it is a function
            method = txt[:index].strip()

            if method in self.methods:
                # This is a method! Make it callable
                return True
            else:
                return False

